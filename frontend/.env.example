# ── DUNIS E-Learning Frontend Environment ────────────────────────────────────
# Copy this file to .env and fill in your values

# Backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# For production, change to your deployed API URL:
# REACT_APP_API_URL=https://api.yourdomain.com/api

# ── Fix for Windows: "allowedHosts[0] should be a non-empty string" ──────────
# This MUST be set on Windows to prevent the Dev Server error
HOST=localhost
DANGEROUSLY_DISABLE_HOST_CHECK=true

# ── Optional port ─────────────────────────────────────────────────────────────
# PORT=3000
