{
  "extends": ["react-app"],
  "rules": {
    "react-hooks/exhaustive-deps": "warn",
    "no-unused-vars": "warn"
  },
  "env": {
    "browser": true,
    "es2020": true,
    "node": true
  },
  "overrides": [
    {
      "files": ["*.jsx"],
      "rules": {
        "react-hooks/exhaustive-deps": "off",
        "no-unused-vars": "off"
      }
    }
  ]
}
