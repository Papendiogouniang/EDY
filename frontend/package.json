{
  "name": "dunis-elearning-frontend",
  "version": "3.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "axios": "^1.6.2",
    "react-player": "^2.14.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "react-markdown": "^9.0.1",
    "framer-motion": "^10.16.16",
    "date-fns": "^3.0.6",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "set CI=false && set DISABLE_ESLINT_PLUGIN=true && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "start:win": "set HOST=localhost && set DANGEROUSLY_DISABLE_HOST_CHECK=true && react-scripts start",
    "vercel-build": "set CI=false && set DISABLE_ESLINT_PLUGIN=true && react-scripts build"
  },
  "proxy": "http://localhost:5000",
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react-hooks/exhaustive-deps": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
