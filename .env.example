# ────────────────────────────────────────────────────────────────────────────
# DUNIS Africa E-Learning — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://dunisadmin:YOURPASSWORD@cluster0.xxxxx.mongodb.net/dunis_elearning?retryWrites=true&w=majority

# JWT Secret (use a long random string in production)
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars_long_for_security
JWT_EXPIRE=7d

# Only emails ending with this domain can register
ALLOWED_EMAIL_DOMAIN=dunis.africa

# Anthropic Claude API key (for AI chatbot)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (for CORS)
CLIENT_URL=http://localhost

# Email SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@dunis.africa
SMTP_PASS=your_smtp_app_password
